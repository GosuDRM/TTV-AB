{
  "name": "ttv-ab",
  "version": "6.3.6",
  "description": "Twitch Ad Blocker",
  "license": "MIT",
  "homepage": "https://github.com/GosuDRM/TTV-AB",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GosuDRM/TTV-AB.git"
  },
  "bugs": {
    "url": "https://github.com/GosuDRM/TTV-AB/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "knip": "^6.1.1",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "knip": "knip --production",
    "lint": "biome check .",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('build',{recursive:true,force:true});\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.runtime.json --noEmit && tsc -p tsconfig.build.json --noEmit",
    "build": "tsc -p tsconfig.build.json && node build/build.js",
    "zip:chrome": "python tools/package_chrome.py",
    "package:chrome": "npm run build && npm run zip:chrome"
  }
}
