{
	"$schema": "https://unpkg.com/knip@6.0.3/schema.json",
	"entry": [
		"build.ts!",
		"src/types/browser-globals.d.ts!",
		"src/modules/*.ts!",
		"src/popup/popup.ts!",
		"src/popup/translations.ts!",
		"src/scripts/background.ts!",
		"src/scripts/bridge.ts!",
		"src/popup/popup.html!"
	],
	"project": ["build.ts!", "src/**/*.ts!", "src/**/*.d.ts!", "src/**/*.html!"]
}
