{
	"compilerOptions": {
		"target": "ES2022",
		"strict": false,
		"noImplicitAny": false,
		"noUnusedLocals": true,
		"useUnknownInCatchVariables": true,
		"noEmitOnError": true,
		"skipLibCheck": true,
		"allowJs": false,
		"checkJs": false,
		"sourceMap": false,
		"declaration": false,
		"removeComments": false,
		"newLine": "lf"
	}
}
